# Basic clinerules configuration for a React + TypeScript + styled-components project

project:
  name: react-ts-styled
  description: Basic setup rules for React with TypeScript and styled-components

rules:
  - name: use-typescript
    description: Ensure all components and files use TypeScript
    enforce: true
    details:
      extensions: [".ts", ".tsx"]

  - name: functional-components-only
    description: Use functional components instead of class components
    enforce: true

  - name: typed-props
    description: All component props must be typed using interfaces or types
    enforce: true

  - name: styled-components-only
    description: Use styled-components for styling instead of CSS/SCSS files
    enforce: true

  - name: avoid-inline-styles
    description: Do not use inline styles in JSX
    enforce: true

  - name: component-structure
    description: Maintain consistent component structure
    enforce: true
    details:
      order:
        - imports
        - types
        - styled-components
        - component
        - export

  - name: file-naming
    description: Use PascalCase for component files
    enforce: true

  - name: hooks-rules
    description: Follow React hooks rules
    enforce: true
    details:
      - only-call-hooks-at-top-level
      - only-call-hooks-in-react-functions

  - name: strict-mode
    description: Enable strict mode in TypeScript
    enforce: true

  - name: folder-structure
    description: Organize project with a scalable folder structure
    enforce: true
    details:
      structure:
        src:
          components: {}
          pages: {}
          hooks: {}
          styles: {}
          utils: {}

  - name: export-default
    description: Use default export for components
    enforce: false

  - name: linting
    description: Use ESLint and Prettier for code quality
    enforce: true
    details:
      tools:
        - eslint
        - prettier

  - name: testing
    description: Encourage unit testing
    enforce: false
    details:
      tools:
        - jest
        - react-testing-library
